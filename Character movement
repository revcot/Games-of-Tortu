import bpy

#bpy.ops.mesh.primitive_cube_add(location=(0,0,1))
#n for seeing object location
#ops is the blenders motion system of moving objects like rotate
#mesh are 3D shapes made of vertices or points
#primitive being the word for simple shape as a cube is a simple shape 
#location + 000 meaning in order x y and z axis
